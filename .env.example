# WalrusOS — Sui Overflow 2025 (Walrus Track)
# Copy this file to .env and fill in your own GEMINI_API_KEY.
# All on-chain IDs below are the publicly-deployed live testnet artifacts —
# you can keep them as-is to reuse the existing LedgerAnchor + package.

WALRUSOS_PACKAGE_ID=0x3339a7cf05650525acb7233eb68c584974b164c4ff03d65e3de8169e41d369e8
WALRUSOS_LEDGER_ANCHOR_ID=0x0f96188ee403ecc58bd498fb874ef3037078775deb68e2061964ac1d3827e27d
WALRUSOS_UPGRADE_CAP_ID=0xac27e694fd2fae8743b2735def5f04fa4cc775d19d58df24f550f5e6985d0067
WALRUSOS_DEPLOYER_ADDRESS=0x114702611c4e6411af933347f2268b32f286af5a05478af8516e670aeb756de1
WALRUSOS_NETWORK=testnet

# Get a Gemini API key at https://aistudio.google.com/apikey (free tier works fine).
GEMINI_API_KEY=

# Optional — override the dashboard bridge URL.
# WALRUSOS_BRIDGE_URL=http://localhost:8787
